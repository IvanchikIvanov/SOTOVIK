# =====================================================================
# Frontend (Vite) — попадает в бандл, секреты сюда НЕ класть.
# =====================================================================

# Supabase (публичный URL + anon ключ)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (для ИИ-ассистента, опционально)
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here


# =====================================================================
# Supabase Edge Function "submit-order" — СЕРВЕРНЫЕ секреты.
# НЕ префиксовать VITE_ и НЕ класть в .env фронта.
# Устанавливать через:
#   supabase secrets set KEY=value KEY2=value2 ...
# или в Dashboard → Edge Functions → Secrets.
# =====================================================================

# Почта первого суперадмина. После создания auth-юзера в Supabase Dashboard
# выполни в SQL Editor:   select public.grant_admin_role('<этот email>', 'superadmin');
# Этот email сюда нужен только как напоминалка — приложение его не читает.
# ADMIN_EMAIL=owner@example.com

# Почта менеджера (куда летят заказы)
# MANAGER_EMAIL=manager@example.com

# Yandex SMTP (smtp.yandex.ru:465, SSL).
# YANDEX_SMTP_PASSWORD — это "Пароль приложения"
# (Яндекс → ID → Безопасность → Пароли приложений). Обычный пароль от почты не работает.
# YANDEX_SMTP_USER=zaberg@yandex.ru
# YANDEX_SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# YANDEX_SMTP_FROM=zaberg@yandex.ru

# Telegram Bot API.
# Создай бота через @BotFather, добавь его в нужный чат.
# chat_id берётся через @userinfobot или запросом getUpdates.
# TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890
